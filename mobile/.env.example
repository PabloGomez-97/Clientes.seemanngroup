# Variables PÚBLICAS que se inyectan en el build de EAS (iOS/Android).
# Configúralas en https://expo.dev → Project → Environment variables → production
# No subas secretos de backend (JWT, MongoDB, R2 keys, etc.) al proyecto mobile.

EXPO_PUBLIC_TURNSTILE_SITE_KEY=
EXPO_PUBLIC_CONTENTFUL_SPACE_ID=
EXPO_PUBLIC_CONTENTFUL_ACCESS_TOKEN=
EXPO_PUBLIC_CONTENTFUL_ENVIRONMENT=master
EXPO_PUBLIC_SHIPSGO_EMBED_TOKEN=
EXPO_PUBLIC_R2_PUBLIC_IMAGES=
