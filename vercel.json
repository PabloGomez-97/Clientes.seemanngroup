{
  "version": 2,
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "env": {
    "NODE_OPTIONS": "--disable-warning=DEP0169"
  },
  "functions": {
    "api/**/*.ts": {
      "memory": 3008,
      "maxDuration": 300
    }
  },
  "crons": [
    {
      "path": "/api/cron/renew-linbis-token",
      "schedule": "0 */23 * * *"
    },
    {
      "path": "/api/cron/pricing-expiry-check",
      "schedule": "0 12 * * *"
    },
    {
      "path": "/api/cron/shipsgo-status-watch",
      "schedule": "*/15 * * * *"
    },
    {
      "path": "/api/cron/cold-client-check",
      "schedule": "0 13 * * *"
    },
    {
      "path": "/api/cron/stale-quote-sessions",
      "schedule": "0 */6 * * *"
    }
  ],
  "rewrites": [
    {
      "source": "/mx/api/:path*",
      "destination": "https://clientes-seemannmexico.vercel.app/api/:path*"
    },
    {
      "source": "/mx",
      "destination": "https://clientes-seemannmexico.vercel.app/mx"
    },
    {
      "source": "/mx/:path*",
      "destination": "https://clientes-seemannmexico.vercel.app/mx/:path*"
    },
    { "source": "/api/:path*", "destination": "/api" },
    { "source": "/(.*)", "destination": "/index.html" }
  ]
}
